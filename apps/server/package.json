{
  "name": "@deliverator/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/apps/server/src/index.js",
  "types": "dist/apps/server/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/apps/server/src/index.d.ts",
      "development": "./src/index.ts",
      "default": "./dist/apps/server/src/index.js"
    }
  },
  "scripts": {
    "build": "vite build --config vite.config.ts && tsc -p tsconfig.json",
    "db:migrate": "tsx src/scripts/migrate.ts",
    "db:seed": "tsx src/scripts/seed.ts",
    "dev": "tsx watch --tsconfig tsconfig.json src/main.ts",
    "lint": "eslint src test web vite.config.ts --ext .ts,.tsx",
    "start": "node dist/apps/server/src/main.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@deliverator/contracts": "workspace:*",
    "@deliverator/core": "workspace:*",
    "@deliverator/db": "workspace:*",
    "@deliverator/shared": "workspace:*",
    "@fastify/vite": "^8.2.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-query": "^5.90.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fastify": "^5.6.0",
    "pino": "^9.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router": "^7.12.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.11"
  }
}
