{
  "name": "@deliverator/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/src/main.js",
  "types": "dist/src/main.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "db:migrate": "NODE_OPTIONS='--conditions=development' tsx src/scripts/migrate.ts",
    "db:seed": "NODE_OPTIONS='--conditions=development' tsx src/scripts/seed.ts",
    "dev": "NODE_OPTIONS='--conditions=development' tsx watch --tsconfig tsconfig.json src/main.ts",
    "dev:container": "NODE_OPTIONS='--conditions=development' tsx watch --tsconfig tsconfig.json src/main.ts",
    "lint": "eslint src test web vite.config.ts --ext .ts,.tsx",
    "start": "node dist/src/main.js",
    "test": "vitest run test/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@deliverator/artifacts": "workspace:*",
    "@deliverator/contracts": "workspace:*",
    "@deliverator/core": "workspace:*",
    "@deliverator/db": "workspace:*",
    "@deliverator/runner": "workspace:*",
    "@deliverator/shared": "workspace:*",
    "@fastify/vite": "^8.2.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.62.2",
    "@opentelemetry/exporter-trace-otlp-http": "^0.204.0",
    "@opentelemetry/sdk-node": "^0.204.0",
    "@opentelemetry/sdk-trace-web": "^2.1.0",
    "fastify": "^5.6.0",
    "pino": "^9.0.0",
    "prom-client": "^15.1.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router": "^7.12.0"
  }
}
