{
  "name": "deliverator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/adapters/*"
  ],
  "scripts": {
    "start": "tsx --conditions=development --tsconfig tsconfig.base.json apps/cli/src/main.ts start",
    "open": "tsx --conditions=development --tsconfig tsconfig.base.json apps/cli/src/main.ts open",
    "logs": "tsx --conditions=development --tsconfig tsconfig.base.json apps/cli/src/main.ts logs",
    "build": "turbo run build",
    "dev": "tsx watch --conditions=development --tsconfig tsconfig.json apps/cli/src/main.ts start",
    "lint": "eslint apps packages --ext .ts,.tsx",
    "test": "vitest run",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.20.6",
    "turbo": "^2.0.0",
    "typescript": "^5.0.0",
    "vite": "^7.0.0",
    "vitest": "^3.0.0"
  }
}
