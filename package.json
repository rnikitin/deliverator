{
  "name": "deliverator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.10.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=@deliverator/server",
    "dev:container": "turbo run dev:container --filter=@deliverator/server",
    "lint": "eslint apps packages --ext .ts,.tsx",
    "test": "vitest run",
    "typecheck": "turbo run typecheck",
    "db:migrate": "pnpm --filter @deliverator/server db:migrate",
    "db:seed": "pnpm --filter @deliverator/server db:seed"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.0.0",
    "vite": "^7.0.0",
    "vitest": "^3.0.0"
  }
}
